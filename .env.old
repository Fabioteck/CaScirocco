APP_NAME="Ca' Scirocco"
APP_ENV=production
APP_KEY=base64:GakrfqUEGdMtss1xv8mxFEMRnNdOGzPZYW9IrCW2Ayk=
APP_DEBUG=false
APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT

# --- URL CONFIGURATION ---
APP_URL=https://www.fabioteck.me
ASSET_URL=https://www.fabioteck.me

# --- SESSION CONFIGURATION ---
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=.fabioteck.me
SESSION_SECURE_COOKIE=true

# --- DATABASE ---
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/scirocco/database/database.sqlite

# --- LOGS & CACHE ---
LOG_CHANNEL=stack
LOG_LEVEL=error
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file

# --- MAIL CONFIGURATION (SMTP - INVIO) ---
MAIL_MAILER=smtp
MAIL_HOST=webmail.cascirocco.it
MAIL_PORT=465
MAIL_USERNAME=info@cascirocco.it
MAIL_PASSWORD=scirocco2020
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=info@cascirocco.it
MAIL_FROM_NAME="${APP_NAME}"

# --- IMAP CONFIGURATION (LETTURA) ---
IMAP_HOST=webmail.cascirocco.it
IMAP_PORT=993
IMAP_ENCRYPTION=ssl
IMAP_PROTOCOL=imap
